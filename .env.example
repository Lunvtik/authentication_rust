# Vorlage. Kopieren nach .env (steht im .gitignore — wird NIE committet).
# Echte Werte lokal setzen; in Produktion über die Secret-Verwaltung der Plattform.

# Welche Umgebungs-Config geladen wird: local | production
APP_ENVIRONMENT=local

# Postgres-Passwort (muss zu compose.yaml passen)
APP_DATABASE__PASSWORD=change-me-strong-db-password

# Redis-Passwort (leer lassen, falls Redis ohne Passwort läuft)
APP_REDIS__PASSWORD=

# Session-/HMAC-Secret — mind. 64 zufällige Bytes.
# Erzeugen z.B. mit:  openssl rand -hex 64
APP_SESSION__SECRET=change-me-64-bytes-random-hex
